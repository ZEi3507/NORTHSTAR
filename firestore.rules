rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /scholars/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'SwbYjFnnW4Pu9o3GQDyfefxZsU42');
    }

    match /sacred-insights/{insightId} {
      allow read, write: if request.auth != null;
    }

    match /archive/{postId} {
      allow read: if request.auth != null && (
        resource.data.status == 'approved' || 
        resource.data.authorId == request.auth.uid || 
        request.auth.uid == 'SwbYjFnnW4Pu9o3GQDyfefxZsU42'
      );
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid || 
        request.auth.uid == 'SwbYjFnnW4Pu9o3GQDyfefxZsU42'
      );

      allow delete: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && resource.data.status != 'approved') || 
        request.auth.uid == 'SwbYjFnnW4Pu9o3GQDyfefxZsU42'
      );
    }

    match /connections/{connectionId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromId && (
        (request.resource.data.type in ['study_partner', 'business_partner'] && request.resource.data.status == 'pending') ||
        (request.resource.data.type == 'follower' && request.resource.data.status == 'accepted')
      );
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.toId && request.resource.data.status == 'accepted' && resource.data.status == 'pending')
      );
      allow delete: if request.auth != null && (request.auth.uid in resource.data.participants);
    }
  }
}
